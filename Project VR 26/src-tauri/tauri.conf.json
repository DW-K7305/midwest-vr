{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MidWest-VR",
  "version": "0.1.0",
  "identifier": "com.localvr.midwestvr",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "MidWest-VR",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "shadow": true,
        "visible": true,
        "trafficLightPosition": { "x": 18, "y": 22 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "resources": ["resources/adb-tools/*"],
    "category": "DeveloperTool",
    "shortDescription": "Meta Quest 2 fleet manager",
    "longDescription": "Locally-managed device, app, and kiosk control for Meta Quest 2 headsets.",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "frameworks": [],
      "exceptionDomain": "",
      "signingIdentity": "-",
      "providerShortName": null,
      "entitlements": null
    }
  },
  "plugins": {
    "shell": { "open": true },
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
