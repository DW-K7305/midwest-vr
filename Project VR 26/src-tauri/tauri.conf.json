{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MidWest-VR",
  "version": "1.46.0",
  "identifier": "com.localvr.midwestvr",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "MidWest-VR",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "shadow": true,
        "visible": true,
        "trafficLightPosition": { "x": 18, "y": 22 }
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' tauri: ipc: data: blob: https://raw.githubusercontent.com https://github.com https://objects.githubusercontent.com https://upload.wikimedia.org https://cdn.sidequestvr.com https://files.sidequestvr.com; connect-src 'self' tauri: ipc: http://ipc.localhost https://raw.githubusercontent.com https://github.com https://objects.githubusercontent.com https://cdn.sidequestvr.com https://files.sidequestvr.com https://dl.google.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "resources": {
      "resources/adb-tools/adb": "adb-tools/adb",
      "resources/midwest-vr-launcher.apk": "midwest-vr-launcher.apk"
    },
    "category": "DeveloperTool",
    "shortDescription": "Meta Quest 2 fleet manager",
    "longDescription": "Locally-managed device, app, and kiosk control for Meta Quest 2 headsets.",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "frameworks": [],
      "exceptionDomain": "",
      "signingIdentity": "-",
      "providerShortName": null,
      "entitlements": null
    }
  },
  "plugins": {
    "shell": { "open": true },
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
